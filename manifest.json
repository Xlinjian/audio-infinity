{
  "manifest_version": 3,
  "name": "Audio无限+",
  "version": "1.0.0",
  "description": "Audio无限+：人声增强、降噪、音量均衡、环绕音效、高级均衡器（EQ），支持 B站 / 百度网盘 / 本地文件 / 任意网页，最高 600% 音量放大。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Audio无限+"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "*://www.bilibili.com/video/*",
        "*://www.bilibili.com/bangumi/play/*",
        "*://www.bilibili.com/list/*",
        "*://www.bilibili.com/festival/*",
        "*://www.bilibili.com/cheese/play/*",
        "*://player.bilibili.com/*",
        "*://www.bilibili.com/blackboard/*",
        "*://*.cctalk.com/*",
        "*://pan.baidu.com/*",
        "*://*.pan.baidu.com/*",
        "file:///*"
      ],
      "js": ["audio-engine.js", "content/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webNavigation"
  ]
}
